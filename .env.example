# Copy this file to .env and fill in the keys you actually use.
# litellm reads these directly.

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Optional: a local OpenAI-compatible endpoint (Ollama, LM Studio server, etc.)
# OPENAI_API_BASE=http://localhost:11434/v1

# Default model used by the runner when --model is not passed.
ANSELM_DEFAULT_MODEL=gpt-4o-mini
